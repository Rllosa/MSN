# =============================================================================
# MSN Unified Messaging Dashboard — Environment Variables
# Copy this file to .env and fill in all values before running.
# Never commit .env to version control.
# =============================================================================

# -----------------------------------------------------------------------------
# PostgreSQL (used by docker compose and the backend)
# -----------------------------------------------------------------------------
POSTGRES_USER=msn
POSTGRES_PASSWORD=changeme
POSTGRES_DB=msn_dashboard
DATABASE_URL=postgresql+asyncpg://msn:changeme@postgres:5432/msn_dashboard

# -----------------------------------------------------------------------------
# Redis
# -----------------------------------------------------------------------------
REDIS_URL=redis://redis:6379/0

# -----------------------------------------------------------------------------
# IMAP — OVH email inbox (info@blackpalm-sxm.com)
# -----------------------------------------------------------------------------
IMAP_HOST=ssl0.ovh.net
IMAP_PORT=993
IMAP_USER=info@blackpalm-sxm.com
IMAP_PASSWORD=changeme
# How often to poll for new emails (seconds)
IMAP_POLL_INTERVAL_SECONDS=30

# -----------------------------------------------------------------------------
# SMTP — for sending Airbnb replies
# -----------------------------------------------------------------------------
SMTP_HOST=ssl0.ovh.net
SMTP_PORT=587
SMTP_USER=info@blackpalm-sxm.com
SMTP_PASSWORD=changeme
SMTP_FROM=info@blackpalm-sxm.com

# -----------------------------------------------------------------------------
# WhatsApp — Meta Cloud API
# -----------------------------------------------------------------------------
WHATSAPP_PHONE_NUMBER_ID=changeme
WHATSAPP_ACCESS_TOKEN=changeme
WHATSAPP_VERIFY_TOKEN=changeme
WHATSAPP_APP_SECRET=changeme
WHATSAPP_API_VERSION=v21.0

# -----------------------------------------------------------------------------
# Auth — JWT
# -----------------------------------------------------------------------------
# Generate with: openssl rand -hex 32
JWT_SECRET_KEY=changeme
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
JWT_REFRESH_TOKEN_EXPIRE_DAYS=30

# -----------------------------------------------------------------------------
# App
# -----------------------------------------------------------------------------
APP_ENV=development
LOG_LEVEL=INFO
FRONTEND_URL=http://localhost:5173

# How many uvicorn workers (1 for dev, 2+ for prod)
WEB_CONCURRENCY=1

# Health check timeouts (seconds)
HEALTH_CHECK_TIMEOUT_SECONDS=5
