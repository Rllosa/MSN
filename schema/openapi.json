      "post": {
        "tags": [
          "webhooks"
        ],
        "summary": "Whatsapp Inbound",
        "description": "Receive an inbound WhatsApp message from Meta Cloud API.\n\nValidates HMAC-SHA256 signature, returns 200 immediately, and processes\nthe payload in a background task so Meta never times out waiting for us.",
