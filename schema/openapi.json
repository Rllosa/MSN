    "/api/conversations/{conv_id}/reply": {
      "post": {
        "tags": [
          "conversations"
        ],
        "summary": "Reply To Conversation",
        "description": "Send an outbound reply to an Airbnb conversation.\n\nRouting:\n- guest_contact ends with @reply.airbnb.com \u2192 SMTP (pre-booking inquiry)\n- guest_contact is numeric                  \u2192 Beds24 API (confirmed booking)",
        "operationId": "reply_to_conversation_api_conversations__conv_id__reply_post",
